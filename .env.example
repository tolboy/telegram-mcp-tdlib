# ═══════════════════════════════════════════════════════════════════════════════
# Telegram MCP Server — Environment Variables
# Copy this file to .env and fill in the values.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Required: TDLib API credentials (from https://my.telegram.org) ───────────
TDLIB_API_ID=12345
TDLIB_API_HASH=your-api-hash-here
# Prefer a mounted secret file in containers or CI; do not set both forms.
TDLIB_API_HASH_FILE=

# ── Authentication (set exactly one) ────────────────────────────────────────
# User-account mode (full API access — recommended):
TDLIB_PHONE_NUMBER=+1234567890
# Bot mode (limited):
# TDLIB_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ── Optional: 2FA and auth code ──────────────────────────────────────────────
TDLIB_2FA_PASSWORD=
TDLIB_AUTH_CODE=
TDLIB_BOT_TOKEN_FILE=
TDLIB_2FA_PASSWORD_FILE=
TDLIB_AUTH_CODE_FILE=
TDLIB_DOWNLOADS_DIR=
TDLIB_LOG_VERBOSITY=1
# Labels shown for this session in Telegram Settings -> Devices.
TDLIB_SYSTEM_LANGUAGE_CODE=en
TDLIB_DEVICE_MODEL=Telegram MCP Server

# ── Optional: TDLib-native proxy ────────────────────────────────────────────
# Type is socks5, http (HTTP CONNECT), or mtproto. Leave TYPE blank for direct.
TDLIB_PROXY_TYPE=
TDLIB_PROXY_SERVER=
TDLIB_PROXY_PORT=0
TDLIB_PROXY_USERNAME=
TDLIB_PROXY_PASSWORD=
TDLIB_PROXY_PASSWORD_FILE=
# For MTProto, prefer a mounted secret file and do not set password fields.
TDLIB_PROXY_SECRET=
TDLIB_PROXY_SECRET_FILE=
# false routes all TDLib traffic through an HTTP CONNECT proxy.
TDLIB_PROXY_HTTP_ONLY=false

# ── MCP Security ─────────────────────────────────────────────────────────────
MCP_API_KEY=your-secure-api-key-here
MCP_API_KEY_FILE=
MCP_AUTH_HEADER=Authorization

# ── Server Mode ──────────────────────────────────────────────────────────────
# Start safe: set false only when your MCP client must perform write actions.
MCP_READ_ONLY=true
# all, reader, inbox, community-admin, or research. Start with reader/inbox.
MCP_TOOL_PROFILE=all
# Require "confirmed": true for destructive operations (delete, ban, leave):
MCP_CONFIRMATION_REQUIRED=true
# Allowed root directories for file operations (comma-separated):
MCP_FILE_ROOTS=
# Audit logging:
MCP_AUDIT_ENABLED=true
MCP_AUDIT_LOG_ARGS=false

# ── Public-chat search (optional, read-only) ─────────────────────────────────
# Restrict discovery to a known set for smoke tests; empty permits normal search.
PUBLIC_SEARCH_ENABLED=true
PUBLIC_SEARCH_CHAT_ALLOWLIST=
PUBLIC_SEARCH_MAX_CHATS_PER_SEARCH=20
PUBLIC_SEARCH_MAX_MESSAGES_PER_CHAT=60
ANTI_SPAM_INTERNAL_CHAT_IDS=

# ── Docker / local convenience ───────────────────────────────────────────────
MCP_UPLOADS_DIR=./docker-data/uploads
KTM_BUILD_DIR=

# ── Optional ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_ALLOWED_CHAT_IDS=
SERVER_PORT=8080
MCP_BIND_HOST=127.0.0.1
# Normally omit this: release artifacts expose their embedded build version.
# Set only to override the server version advertised to an MCP client.
# MCP_SERVER_VERSION=1.3.1
# Blank uses the OS app-data convention. Use an absolute path for a custom volume.
TDLIB_DATA_DIR=
# Optional base directory for automatic per-account storage. Docker sets this
# to its persisted /data/tdlib-data volume automatically.
TELEGRAM_MCP_DATA_DIR=

# ── Multi-account (optional) ─────────────────────────────────────────────────
# Every label gets an isolated TDLib session directory. In multi-account mode
# every MCP tool call must include `account`, and scoped API keys can restrict
# a client to one label. Do not put real credentials in this example file.
# TELEGRAM_ACCOUNTS_WORK_API_ID=12345
# TELEGRAM_ACCOUNTS_WORK_API_HASH_FILE=/absolute/path/to/work-api-hash
# TELEGRAM_ACCOUNTS_WORK_PHONE_NUMBER=+1234567890
# TELEGRAM_ACCOUNTS_PERSONAL_API_ID=12345
# TELEGRAM_ACCOUNTS_PERSONAL_API_HASH_FILE=/absolute/path/to/personal-api-hash
# TELEGRAM_ACCOUNTS_PERSONAL_PHONE_NUMBER=+1987654321
# TELEGRAM_ACCOUNTS_WORK_PROXY_TYPE=socks5
# TELEGRAM_ACCOUNTS_WORK_PROXY_SERVER=proxy.example.net
# TELEGRAM_ACCOUNTS_WORK_PROXY_PORT=1080
# TELEGRAM_ACCOUNTS_WORK_PROXY_USERNAME=work-user
# TELEGRAM_ACCOUNTS_WORK_PROXY_PASSWORD_FILE=/run/secrets/work_proxy_password
# MCP_SECURITY_CLIENTS_0_ID=work-agent
# MCP_SECURITY_CLIENTS_0_API_KEY_FILE=/absolute/path/to/work-mcp-key
# MCP_SECURITY_CLIENTS_0_ALLOWED_ACCOUNTS_0=work
